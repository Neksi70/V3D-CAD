rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Gespeicherte Designs — nur der eigene Nutzer
    match /users/{uid}/designs/{designId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Kurs-/Tutorial-Fortschritt — nur der eigene Nutzer
    match /users/{uid}/progress/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Abstimmungen — oeffentlich lesbar; jeder darf abstimmen (Stimmen-Zaehler),
    // aber Frage/Optionen/Besitzer duerfen nicht veraendert werden.
    // Erstellen nur angemeldet; loeschen nur der Ersteller.
    // Geteilte 3D-Modelle (read-only Link) — oeffentlich lesbar; erstellen nur
    // angemeldet, loeschen nur der Ersteller. Inhalt unveraenderlich.
    match /shared/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.createdBy;
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.resource.data.question == resource.data.question
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.options.size() == resource.data.options.size();
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.createdBy;
    }
  }
}
