[Unit]
Description=Volme3D Webserver
After=network.target

[Service]
WorkingDirectory=/home/v3da
# Vor dem Start die gehaertete dist neu bauen. Fuehrendes '-' = Fehler
# ignorieren, damit der Server auch bei Build-Problemen hochkommt
# (faellt dann auf letzte dist bzw. lesbare volme3d.html zurueck).
ExecStartPre=-/usr/bin/node /home/v3da/build.js
ExecStart=python3 /home/v3da/volme3d_server.py 8765
Restart=always

[Install]
WantedBy=default.target
